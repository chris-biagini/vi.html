{
  "name": "vi.html",
  "version": "1.0.0",
  "private": true,
  "description": "Single-file markdown editor with vim keybindings",
  "type": "commonjs",
  "scripts": {
    "build": "node build.js",
    "build:min": "node build.js --minify",
    "dev": "node build.js --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ && prettier --check src/",
    "lint:fix": "eslint src/ --fix && prettier --write src/",
    "check": "npm run lint && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chris-biagini/vi.html.git"
  },
  "license": "MIT",
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "@replit/codemirror-vim": "^6.3.0",
    "codemirror": "^6.0.2",
    "marked": "^17.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "vitest": "^4.0.18"
  }
}
